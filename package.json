{
  "name": "quiz-voice-engine",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Kompetitive Voice-Quiz Engine - responsive Echtzeit-Web-App (Handy/Tablet/PC)",
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -k -n SERVER,CLIENT -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev -w server",
    "dev:client": "npm run dev -w client",
    "build": "npm run build -w client",
    "start": "npm run start -w server"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
